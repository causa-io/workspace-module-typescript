{
  "name": "@causa/workspace-typescript",
  "version": "1.1.0",
  "description": "The Causa workspace module providing functionalities for projects coded in TypeScript.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/causa-io/workspace-module-typescript.git"
  },
  "license": "ISC",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./code-generation": "./dist/code-generation/index.js",
    "./services": "./dist/services/index.js"
  },
  "files": [
    "dist/",
    "LICENSE.md",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "prebuild": "rimraf ./dist",
    "build": "tsc -p tsconfig.build.json",
    "postbuild": "copyfiles -u 1 src/**/assets/**/* dist/ && node transform-schemas.mjs",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "NODE_OPTIONS=\"--experimental-vm-modules --no-warnings=ExperimentalWarning\" jest",
    "test:cov": "npm run test -- --coverage",
    "typecheck": "tsc --noEmit",
    "generateConfigurationSchemas": "cs model genCode && perl -pi -e 's|\\@causa/runtime|\\@causa/workspace/validation|g' src/configurations/generated.ts"
  },
  "dependencies": {
    "@causa/workspace": "^1.0.1",
    "@causa/workspace-core": "^1.1.0",
    "archiver": "^8.0.0",
    "audit-ci": "^7.1.0",
    "change-case": "^5.4.4",
    "class-validator": "^0.15.1",
    "globby": "^16.2.0",
    "micromatch": "^4.0.8",
    "npm-check-updates": "^22.2.3",
    "pino": "^10.3.1",
    "prettier": "^3.8.4",
    "semver": "^7.8.4",
    "tar": "^7.5.16",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@scalar/openapi-types": "^0.9.1",
    "@swc/core": "^1.15.41",
    "@swc/jest": "^0.2.39",
    "@tsconfig/node22": "^22.0.5",
    "@types/archiver": "^8.0.0",
    "@types/jest": "^30.0.0",
    "@types/micromatch": "^4.0.10",
    "@types/node": "^20.19.43",
    "@types/semver": "^7.7.1",
    "copyfiles": "^2.4.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "jest": "^30.4.2",
    "jest-extended": "^7.0.0",
    "node-stream-zip": "^1.15.0",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  }
}
